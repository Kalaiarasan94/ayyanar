# Copy this file to `.env` for local development, or set these
# as Environment Variables in Hostinger hPanel for production.

# --- MySQL Database (from hPanel -> Databases -> MySQL Databases) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=construction_erp

# --- Server ---
# Hostinger sets PORT automatically; only set this for local development
# PORT=5000
